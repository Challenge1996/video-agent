TTS_PROVIDER=minimax

GOOGLE_APPLICATION_CREDENTIALS=./credentials/google-cloud-key.json
GOOGLE_TTS_LANGUAGE_CODE=zh-CN
GOOGLE_TTS_VOICE_NAME=zh-CN-Wavenet-A
GOOGLE_TTS_SPEAKING_RATE=1.0
GOOGLE_TTS_PITCH=0.0

MINIMAX_API_KEY=your_minimax_api_key
MINIMAX_GROUP_ID=your_minimax_group_id
MINIMAX_BASE_URL=https://api.minimax.chat/v1/t2a_v2
MINIMAX_MODEL=speech-2.8-hd
MINIMAX_VOICE_ID=male-qn-qingse
MINIMAX_SPEED=1.0
MINIMAX_VOL=1.0
MINIMAX_PITCH=0.0
MINIMAX_EMOTION=happy
MINIMAX_SAMPLE_RATE=32000
MINIMAX_BITRATE=128000
MINIMAX_FORMAT=mp3
MINIMAX_CHANNEL=1

MINIMAX_LLM_BASE_URL=https://api.minimaxi.com/anthropic
LLM_PROVIDER=minimax
LLM_MODEL=MiniMax-M2.7
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1

# ffmpeg 路径（如果 ffmpeg 不在系统 PATH 中，不需要设置）
# FFMPEG_PATH=/usr/local/bin/ffmpeg
# FFPROBE_PATH=/usr/local/bin/ffprobe

OUTPUT_DIR=./output
TEMP_DIR=./temp

WEB_SERVER_HOST=0.0.0.0
WEB_SERVER_PORT=8000
